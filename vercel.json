{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "",
  "installCommand": "",
  "outputDirectory": ".",
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/",
      "destination": "https://world-model-gym.vercel.app/",
      "permanent": false
    },
    {
      "source": "/(.*)",
      "destination": "https://world-model-gym.vercel.app/$1",
      "permanent": false
    }
  ]
}
